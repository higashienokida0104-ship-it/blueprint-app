{
  "version": 2,
  "routes": [
    { "src": "/API/(.*)", "dest": "/api/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*\\.(?:png|svg|ico|webp|gif|jpg|jpeg))", "dest": "/$1" },
    { "src": "/sw\\.js",         "dest": "/sw.js" },
    { "src": "/manifest\\.json", "dest": "/manifest.json" },
    { "src": "/(.*)",            "dest": "/blueprint.html" }
  ]
}
